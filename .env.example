SECRET_KEY=your-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# APK (update on each release)
APK_URL=https://github.com/kennedy-ak/ispeye-download/releases/download/v1.3.1/app-release.apk
APK_FILENAME=ispeye-v1.3.1.apk
APK_VERSION=1.3.1

# Public URL of the site (used in approval emails)
APP_BASE_URL=http://localhost:8000

# Database (leave blank for SQLite in dev; Railway sets this automatically)
DATABASE_URL=

# Email — use Django console backend for dev, SMTP for prod
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=iSpeye <noreply@ispeye.app>
ADMIN_EMAIL=belmontsolutionsgh@gmail.com
